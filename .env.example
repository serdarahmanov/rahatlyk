# ─────────────────────────────────────────────────────────────
#  RAHATLYK — environment variables template
#  Copy this file to .env.local and fill in real values.
#  This file IS committed to git (no real secrets here).
# ─────────────────────────────────────────────────────────────

# ── Site ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://rahatlyk.com

# ── Google Maps (contact page map embed) ──────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── Contact form — Gmail SMTP ──────────────────────────────────
CONTACT_FORM_TO_EMAIL=info@rahatlyk.com
NOREPLY_EMAIL=noreply@rahatlyk.com
WEBSITE_EMAIL=website@rahatlyk.com
GMAIL_USER=your.gmail@gmail.com
# Use a Gmail App Password, NOT your real Gmail password:
# https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
